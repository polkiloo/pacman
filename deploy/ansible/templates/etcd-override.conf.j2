[Service]
ExecStart=
ExecStart={{ etcd_binary_path }} \
  --name {{ etcd_name | default(inventory_hostname) }} \
  --data-dir {{ etcd_data_dir }} \
  --listen-client-urls http://0.0.0.0:{{ etcd_client_port }} \
  --advertise-client-urls {{ etcd_client_advertise_url | default('http://' ~ (ansible_host | default(ansible_default_ipv4.address)) ~ ':' ~ etcd_client_port) }} \
  --listen-peer-urls http://0.0.0.0:{{ etcd_peer_port }} \
  --initial-advertise-peer-urls {{ etcd_peer_advertise_url | default('http://' ~ (ansible_host | default(ansible_default_ipv4.address)) ~ ':' ~ etcd_peer_port) }} \
  --initial-cluster {{ etcd_name | default(inventory_hostname) }}={{ etcd_peer_advertise_url | default('http://' ~ (ansible_host | default(ansible_default_ipv4.address)) ~ ':' ~ etcd_peer_port) }} \
  --initial-cluster-state new
Restart=on-failure
