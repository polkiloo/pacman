apiVersion: pacman.io/v1alpha1
kind: NodeConfig

node:
  name: "{{ pacman_node_name | default(inventory_hostname) }}"
  role: data
  apiAddress: "{{ pacman_api_address | default((ansible_host | default(ansible_default_ipv4.address | default(inventory_hostname))) ~ ':' ~ pacman_api_port) }}"
  controlAddress: "{{ pacman_control_address | default((ansible_host | default(ansible_default_ipv4.address | default(inventory_hostname))) ~ ':' ~ pacman_control_port) }}"

dcs:
  backend: etcd
  clusterName: "{{ pacman_cluster_name }}"
  ttl: 30s
  retryTimeout: 10s
  etcd:
    endpoints:
{% for host in groups['dcs_nodes'] %}
      - "{{ hostvars[host].etcd_client_advertise_url | default('http://' ~ (hostvars[host].ansible_host | default(hostvars[host].ansible_default_ipv4.address | default(host))) ~ ':' ~ etcd_client_port) }}"
{% endfor %}

{% if pacman_tls_enabled %}
tls:
  enabled: true
  caFile: "{{ pacman_tls_ca_path }}"
  certFile: "{{ pacman_tls_cert_path }}"
  keyFile: "{{ pacman_tls_key_path }}"
{% if pacman_tls_server_name | length > 0 %}
  serverName: "{{ pacman_tls_server_name }}"
{% endif %}
  insecureSkipVerify: {{ pacman_tls_insecure_skip_verify | bool | lower }}

{% endif %}
security:
  adminBearerTokenFile: "{{ pacman_admin_token_path }}"
{% if pacman_security_member_mtls_enabled | bool %}
  memberMTLSEnabled: true
{% endif %}

postgres:
  dataDir: "{{ postgres_data_dir }}"
  binDir: "{{ postgres_bin_dir }}"
  listenAddress: "{{ postgres_listen_address }}"
  port: {{ postgres_port }}
  replicationUser: "{{ postgres_replication_user }}"
  replicationPassword: "{{ postgres_replication_password }}"

{% if pacman_reinit_walg_enabled | bool %}
reinit:
  walg:
    binary: "{{ pacman_reinit_walg_binary }}"
    repository:
      provider: "{{ pacman_reinit_walg_repository_provider }}"
      prefix: "{{ pacman_reinit_walg_repository_prefix }}"
{% if pacman_reinit_walg_repository_endpoint | length > 0 %}
      endpoint: "{{ pacman_reinit_walg_repository_endpoint }}"
{% endif %}
{% if pacman_reinit_walg_repository_region | length > 0 %}
      region: "{{ pacman_reinit_walg_repository_region }}"
{% endif %}
    restore:
      backupName: "{{ pacman_reinit_walg_restore_backup_name }}"
{% if pacman_reinit_walg_environment or pacman_reinit_walg_environment_file_values or pacman_reinit_walg_environment_files or pacman_reinit_walg_inherit_environment %}
    credentials:
{% if pacman_reinit_walg_inherit_environment %}
      inheritEnvironment:
{% for name in pacman_reinit_walg_inherit_environment %}
        - "{{ name }}"
{% endfor %}
{% endif %}
{% if pacman_reinit_walg_environment %}
      environment:
{% for name, value in pacman_reinit_walg_environment | dictsort %}
        {{ name }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if pacman_reinit_walg_environment_file_values or pacman_reinit_walg_environment_files %}
      environmentFiles:
{% for name, value in pacman_reinit_walg_environment_file_values | dictsort %}
        {{ name }}: "{{ pacman_reinit_walg_environment_file_dir }}/{{ name }}"
{% endfor %}
{% for name, path in pacman_reinit_walg_environment_files | dictsort %}
        {{ name }}: "{{ path }}"
{% endfor %}
{% endif %}
{% endif %}

{% endif %}
bootstrap:
  clusterName: "{{ pacman_cluster_name }}"
  initialPrimary: "{{ pacman_initial_primary }}"
  seedAddresses:
{% for host in groups['postgres_nodes'] %}
    - "{{ hostvars[host].pacman_control_address | default((hostvars[host].ansible_host | default(hostvars[host].ansible_default_ipv4.address | default(host))) ~ ':' ~ pacman_control_port) }}"
{% endfor %}
  expectedMembers:
{% for host in groups['postgres_nodes'] %}
    - "{{ hostvars[host].pacman_node_name | default(host) }}"
{% endfor %}
