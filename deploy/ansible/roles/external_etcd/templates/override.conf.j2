[Service]
ExecStart=
ExecStart={{ etcd_binary_path }} \
  --name {{ etcd_name | default(inventory_hostname) }} \
  --data-dir {{ etcd_data_dir }} \
  --listen-client-urls http://0.0.0.0:{{ etcd_client_port }} \
  --advertise-client-urls {{ etcd_client_advertise_url | default('http://' ~ (ansible_host | default(ansible_default_ipv4.address | default(inventory_hostname))) ~ ':' ~ etcd_client_port) }} \
  --listen-peer-urls http://0.0.0.0:{{ etcd_peer_port }} \
  --initial-advertise-peer-urls {{ etcd_peer_advertise_url | default('http://' ~ (ansible_host | default(ansible_default_ipv4.address | default(inventory_hostname))) ~ ':' ~ etcd_peer_port) }} \
  --initial-cluster {% for host in groups['dcs_nodes'] %}{{ hostvars[host].etcd_name | default(host) }}={{ hostvars[host].etcd_peer_advertise_url | default('http://' ~ (hostvars[host].ansible_host | default(hostvars[host].ansible_default_ipv4.address | default(host))) ~ ':' ~ etcd_peer_port) }}{% if not loop.last %},{% endif %}{% endfor %} \
  --initial-cluster-state {{ etcd_initial_cluster_state }} \
  --initial-cluster-token {{ etcd_initial_cluster_token }}
Restart=on-failure
