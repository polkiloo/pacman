#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/docker-lab.sh
source "${script_dir}/../lib/docker-lab.sh"
# shellcheck source=../lib/workloads.sh
source "${script_dir}/../lib/workloads.sh"

require_tool docker
require_tool jq

campaign="nightly"
cases="${PACMAN_JEPSEN_CASES:-append-smoke:none append-failover:kill single-key-register:packet read-committed-txn:slow-network serializable-txn:packet,kill append-failover:repeated-failure}"
run_dir="$(run_dir_for "${campaign}")"
history_file="${run_dir}/jepsen-history.edn"

export PACMAN_JEPSEN_CAMPAIGN="${campaign}"

mkdir -p "${run_dir}"
: >"${history_file}"

finish() {
  local exit_status=$?
  local valid=false

  if [[ "${exit_status}" -eq 0 ]]; then
    valid=true
  fi

  collect_artifacts "${run_dir}" "${valid}"

  if [[ "${exit_status}" -eq 0 ]]; then
    printf 'PACMAN Jepsen nightly artifacts: %s\n' "${run_dir}"
  fi
}

trap finish EXIT

: >"${run_dir}/nemesis-schedule.edn"

write_edn_event "${history_file}" "bootstrap" "invoke" "\"docker-lab\""
bootstrap_lab
write_edn_event "${history_file}" "bootstrap" "ok" "\"docker-lab\""

compose_exec pacman-primary /bin/sh -lc \
  "PACMANCTL_API_URL=http://pacman-primary:8080 PACMANCTL_API_TOKEN=lab-admin-token pacmanctl cluster status -o json" \
  >"${run_dir}/pacman-cluster-before.json"

write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify-before\""
verify_lab
write_edn_event "${history_file}" "verify" "ok" "\"demo-verify-before\""

write_edn_event "${history_file}" "cases" "invoke" "\"${cases}\""
run_jepsen_cases "${cases}" "${run_dir}" "${history_file}" "${run_dir}/nemesis-schedule.edn"
write_edn_event "${history_file}" "cases" "ok" "\"${cases}\""

write_edn_event "${history_file}" "switchover" "invoke" "\"alpha-2\""
"${repo_root}/deploy/lab/scripts/demo.sh" switchover alpha-2
write_edn_event "${history_file}" "switchover" "ok" "\"alpha-2\""

write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify-after\""
verify_lab
write_edn_event "${history_file}" "verify" "ok" "\"demo-verify-after\""
