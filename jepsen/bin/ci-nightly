#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/docker-lab.sh
source "${script_dir}/../lib/docker-lab.sh"
# shellcheck source=../lib/workloads.sh
source "${script_dir}/../lib/workloads.sh"

require_tool docker
require_tool jq

campaign="nightly"
cases="$(jepsen_cases_for_campaign "${campaign}")"
run_dir="$(run_dir_for "${campaign}")"
history_file="${run_dir}/jepsen-history.edn"

export PACMAN_JEPSEN_CAMPAIGN="${campaign}"

mkdir -p "${run_dir}"
: >"${history_file}"
: >"${run_dir}/nightly-failures.txt"

finish() {
  local exit_status=$?
  local valid=false

  if [[ "${exit_status}" -eq 0 ]]; then
    valid=true
  fi

  collect_artifacts "${run_dir}" "${valid}"
  if ! destroy_lab_after_suite "${run_dir}" "${history_file}"; then
    exit_status=1
    write_results_file "${run_dir}" false
  fi

  if [[ "${exit_status}" -eq 0 ]]; then
    printf 'PACMAN Jepsen nightly artifacts: %s\n' "${run_dir}"
  fi

  exit "${exit_status}"
}

trap finish EXIT

: >"${run_dir}/nemesis-schedule.edn"
mkdir -p "${run_dir}/cases"
: >"${run_dir}/case-results.jsonl"

failed=0
failed_cases=()

write_edn_event "${history_file}" "cases" "invoke" "\"${cases}\""

for spec in ${cases}; do
  workload=${spec%%:*}
  nemesis=${spec#*:}
  if [[ "${workload}" == "${nemesis}" ]]; then
    nemesis="none"
  fi

  slug="$(case_slug "${workload}__${nemesis}")"

  write_edn_event "${history_file}" "bootstrap" "invoke" "\"docker-lab:${workload}:${nemesis}\""
  if bootstrap_lab_with_retries "${workload}:${nemesis}"; then
    write_edn_event "${history_file}" "bootstrap" "ok" "\"docker-lab:${workload}:${nemesis}\""
  else
    write_edn_event "${history_file}" "bootstrap" "fail" "\"docker-lab:${workload}:${nemesis}\""
    printf '%s:%s bootstrap failed\n' "${workload}" "${nemesis}" >>"${run_dir}/nightly-failures.txt"
    failed_cases+=("${workload}:${nemesis}:bootstrap")
    failed=1
    continue
  fi

  write_edn_event "${history_file}" "cluster" "invoke" "\"three-data-node:${workload}:${nemesis}\""
  if verify_three_data_node_cluster "${run_dir}/pacman-cluster-before-${slug}.json"; then
    write_edn_event "${history_file}" "cluster" "ok" "\"three-data-node:${workload}:${nemesis}\""
  else
    write_edn_event "${history_file}" "cluster" "fail" "\"three-data-node:${workload}:${nemesis}\""
    printf '%s:%s cluster shape failed\n' "${workload}" "${nemesis}" >>"${run_dir}/nightly-failures.txt"
    failed_cases+=("${workload}:${nemesis}:cluster")
    failed=1
    continue
  fi

  write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify-before:${workload}:${nemesis}\""
  if verify_lab; then
    write_edn_event "${history_file}" "verify" "ok" "\"demo-verify-before:${workload}:${nemesis}\""
  else
    write_edn_event "${history_file}" "verify" "fail" "\"demo-verify-before:${workload}:${nemesis}\""
    printf '%s:%s verify-before failed\n' "${workload}" "${nemesis}" >>"${run_dir}/nightly-failures.txt"
    failed_cases+=("${workload}:${nemesis}:verify-before")
    failed=1
    continue
  fi

  ensure_workload_schema

  if ! run_jepsen_case "${workload}" "${nemesis}" "${run_dir}" "${history_file}" "${run_dir}/nemesis-schedule.edn" "${run_dir}/case-results.jsonl"; then
    printf '%s:%s case failed\n' "${workload}" "${nemesis}" >>"${run_dir}/nightly-failures.txt"
    failed_cases+=("${workload}:${nemesis}:case")
    failed=1
  fi

  write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify-after:${workload}:${nemesis}\""
  if verify_lab; then
    write_edn_event "${history_file}" "verify" "ok" "\"demo-verify-after:${workload}:${nemesis}\""
  else
    write_edn_event "${history_file}" "verify" "fail" "\"demo-verify-after:${workload}:${nemesis}\""
    printf '%s:%s verify-after failed\n' "${workload}" "${nemesis}" >>"${run_dir}/nightly-failures.txt"
    failed_cases+=("${workload}:${nemesis}:verify-after")
    failed=1
  fi
done

if [[ "${failed}" -eq 0 ]]; then
  write_edn_event "${history_file}" "cases" "ok" "\"${cases}\""
else
  write_edn_event "${history_file}" "cases" "fail" "\"${cases}\""
fi

write_edn_event "${history_file}" "bootstrap" "invoke" "\"docker-lab:post-campaign\""
if bootstrap_lab_with_retries "post-campaign"; then
  write_edn_event "${history_file}" "bootstrap" "ok" "\"docker-lab:post-campaign\""

  write_edn_event "${history_file}" "switchover" "invoke" "\"auto\""
  if "${repo_root}/deploy/lab/scripts/demo.sh" switchover; then
    write_edn_event "${history_file}" "switchover" "ok" "\"auto\""
  else
    write_edn_event "${history_file}" "switchover" "fail" "\"auto\""
    printf 'post-campaign switchover failed\n' >>"${run_dir}/nightly-failures.txt"
    failed_cases+=("post-campaign:switchover")
    failed=1
  fi

  write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify-after\""
  if verify_lab; then
    write_edn_event "${history_file}" "verify" "ok" "\"demo-verify-after\""
  else
    write_edn_event "${history_file}" "verify" "fail" "\"demo-verify-after\""
    printf 'post-campaign verify failed\n' >>"${run_dir}/nightly-failures.txt"
    failed_cases+=("post-campaign:verify")
    failed=1
  fi
else
  write_edn_event "${history_file}" "bootstrap" "fail" "\"docker-lab:post-campaign\""
  printf 'post-campaign bootstrap failed\n' >>"${run_dir}/nightly-failures.txt"
  failed_cases+=("post-campaign:bootstrap")
  failed=1
fi

if [[ "${failed}" -ne 0 ]]; then
  printf 'PACMAN Jepsen nightly failed. Failure summary:\n' >&2
  if [[ "${#failed_cases[@]}" -gt 0 ]]; then
    printf '  - %s\n' "${failed_cases[@]}" >&2
  else
    printf '  - unknown failure; inspect %s\n' "${run_dir}" >&2
  fi
  printf 'Artifacts: %s\n' "${run_dir}" >&2
fi

exit "${failed}"
