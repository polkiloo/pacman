#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/docker-lab.sh
source "${script_dir}/../lib/docker-lab.sh"
# shellcheck source=../lib/workloads.sh
source "${script_dir}/../lib/workloads.sh"

require_tool docker
require_tool jq

campaign="smoke"
cases="$(jepsen_cases_for_campaign "${campaign}")"
run_dir="$(run_dir_for "${campaign}")"
history_file="${run_dir}/jepsen-history.edn"

export PACMAN_JEPSEN_CAMPAIGN="${campaign}"

mkdir -p "${run_dir}"
: >"${history_file}"

finish() {
  local exit_status=$?
  local valid=false

  if [[ "${exit_status}" -eq 0 ]]; then
    valid=true
  fi

  collect_artifacts "${run_dir}" "${valid}"
  if ! destroy_lab_after_suite "${run_dir}" "${history_file}"; then
    exit_status=1
    write_results_file "${run_dir}" false
  fi

  if [[ "${exit_status}" -eq 0 ]]; then
    printf 'PACMAN Jepsen smoke artifacts: %s\n' "${run_dir}"
  fi

  exit "${exit_status}"
}

trap finish EXIT

: >"${run_dir}/nemesis-schedule.edn"

write_edn_event "${history_file}" "bootstrap" "invoke" "\"docker-lab\""
bootstrap_lab
write_edn_event "${history_file}" "bootstrap" "ok" "\"docker-lab\""

write_edn_event "${history_file}" "cluster" "invoke" "\"three-data-node\""
verify_three_data_node_cluster "${run_dir}/pacman-cluster-before.json"
write_edn_event "${history_file}" "cluster" "ok" "\"three-data-node\""

write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify\""
verify_lab
write_edn_event "${history_file}" "verify" "ok" "\"demo-verify\""

write_edn_event "${history_file}" "cases" "invoke" "\"${cases}\""
run_jepsen_cases "${cases}" "${run_dir}" "${history_file}" "${run_dir}/nemesis-schedule.edn"
write_edn_event "${history_file}" "cases" "ok" "\"${cases}\""

write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify-after-cases\""
verify_lab
write_edn_event "${history_file}" "verify" "ok" "\"demo-verify-after-cases\""
