#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: jepsen/bin/ci-case <case-name|workload:nemesis>

Run one PACMAN Jepsen case against the Docker lab.
Use jepsen/bin/list-cases to see supported names.
EOF
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/docker-lab.sh
source "${script_dir}/../lib/docker-lab.sh"
# shellcheck source=../lib/workloads.sh
source "${script_dir}/../lib/workloads.sh"

require_tool docker
require_tool jq

case_name="${1:-${PACMAN_JEPSEN_CASE:-}}"
if [[ -z "${case_name}" ]]; then
  usage
  exit 2
fi

case_spec="$(resolve_jepsen_case_spec "${case_name}")"
case_slug_name="$(case_slug "${case_spec}")"
campaign="case-${case_slug_name}"
run_dir="$(run_dir_for "${campaign}")"
history_file="${run_dir}/jepsen-history.edn"

export PACMAN_JEPSEN_CAMPAIGN="${campaign}"

mkdir -p "${run_dir}"
: >"${history_file}"

finish() {
  local exit_status=$?
  local valid=false

  if [[ "${exit_status}" -eq 0 ]]; then
    valid=true
  fi

  collect_artifacts "${run_dir}" "${valid}"

  if [[ "${exit_status}" -eq 0 ]]; then
    printf 'PACMAN Jepsen case artifacts: %s\n' "${run_dir}"
  fi
}

trap finish EXIT

: >"${run_dir}/nemesis-schedule.edn"

write_edn_event "${history_file}" "bootstrap" "invoke" "\"docker-lab\""
bootstrap_lab
write_edn_event "${history_file}" "bootstrap" "ok" "\"docker-lab\""

compose_exec pacman-primary /bin/sh -lc \
  "PACMANCTL_API_URL=http://pacman-primary:8080 PACMANCTL_API_TOKEN=lab-admin-token pacmanctl cluster status -o json" \
  >"${run_dir}/pacman-cluster-before.json"

write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify-before\""
verify_lab
write_edn_event "${history_file}" "verify" "ok" "\"demo-verify-before\""

write_edn_event "${history_file}" "case" "invoke" "\"${case_spec}\""
run_jepsen_cases "${case_spec}" "${run_dir}" "${history_file}" "${run_dir}/nemesis-schedule.edn"
write_edn_event "${history_file}" "case" "ok" "\"${case_spec}\""

write_edn_event "${history_file}" "verify" "invoke" "\"demo-verify-after-case\""
verify_lab
write_edn_event "${history_file}" "verify" "ok" "\"demo-verify-after-case\""
